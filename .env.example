POCKET_HTTP_PORT=8088
POCKET_DB_PATH=./data/pocket.sqlite
POCKET_INSTANCE_DISCOVERY_BASE_URL=https://discovery.example.internal
POCKET_INSTANCE_DISCOVERY_AUTH_TOKEN=<INSTANCE_DISCOVERY_AUTH_TOKEN>
POCKET_INSTANCE_CATALOG_JSON='[{"id":"demo-main","displayName":"Demo Main","apiBaseURL":"https://opencode.example.internal","environment":"development"}]'
POCKET_OPENCODE_TIMEOUT_MS=5000
POCKET_WS_HEARTBEAT_MS=15000
POCKET_REMINDER_CHECK_INTERVAL_SEC=60
POCKET_ANDROID_APP_ID=com.example.opencode.pocket
POCKET_ANDROID_USE_CAPACITOR=true
