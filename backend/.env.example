# ============================================================================
# Pocket Backend Configuration Example
# ============================================================================
# 复制此文件为 .env 并根据实际环境填写配置值
# Copy this file to .env and fill in values for your environment

# ----------------------------------------------------------------------------
# 基础服务配置 / Basic Service Configuration
# ----------------------------------------------------------------------------

# HTTP 服务端口 / HTTP server port
POCKET_HTTP_PORT=8088

# SQLite 数据库路径（已弃用，仅用于 data 目录定位）
# SQLite database path (deprecated, only for data directory location)
POCKET_DB_PATH=./data/pocket.sqlite

# PostgreSQL 数据库连接字符串（Phase 0 统一数据层）
# PostgreSQL DSN (Phase 0 unified data layer)
# 格式：postgres://user:password@host:port/dbname?sslmode=disable
POCKET_POSTGRES_DSN=
# 或者使用标准环境变量 / Or use standard DATABASE_URL
DATABASE_URL=

# ----------------------------------------------------------------------------
# 实例发现服务 / Instance Discovery Service
# ----------------------------------------------------------------------------

# NPS 服务基础 URL（实例发现）/ NPS service base URL
POCKET_NPS_BASE_URL=
# 或使用新命名 / Or use new naming
POCKET_INSTANCE_DISCOVERY_BASE_URL=

# NPS 认证令牌 / NPS auth token
POCKET_NPS_AUTH_KEY=
# 或使用新命名 / Or use new naming
POCKET_INSTANCE_DISCOVERY_AUTH_TOKEN=

# NPS 认证加密密钥 / NPS auth encryption key
POCKET_NPS_AUTH_CRYPT_KEY=
# 或使用新命名 / Or use new naming
POCKET_INSTANCE_DISCOVERY_AUTH_SECRET=

# OpenCode 实例列表 JSON 配置 / OpenCode instances JSON catalog
POCKET_OPENCODE_INSTANCES=
# 或使用新命名 / Or use new naming
POCKET_INSTANCE_CATALOG_JSON=

# OpenCode 请求超时（毫秒）/ OpenCode request timeout in milliseconds
POCKET_OPENCODE_TIMEOUT_MS=5000

# ----------------------------------------------------------------------------
# WebSocket 配置 / WebSocket Configuration
# ----------------------------------------------------------------------------

# WebSocket 心跳间隔（毫秒）/ WebSocket heartbeat interval in milliseconds
POCKET_WS_HEARTBEAT_MS=15000

# ----------------------------------------------------------------------------
# 提醒服务 / Reminder Service
# ----------------------------------------------------------------------------

# 提醒检查间隔（秒）/ Reminder check interval in seconds
POCKET_REMINDER_CHECK_INTERVAL_SEC=60

# ----------------------------------------------------------------------------
# Android 应用配置 / Android App Configuration
# ----------------------------------------------------------------------------

# Android 应用包名 / Android app package ID
POCKET_ANDROID_APP_ID=com.kaixuan.opencode.pocket

# 是否使用 Capacitor Shell / Use Capacitor shell
POCKET_ANDROID_USE_CAPACITOR=true

# ----------------------------------------------------------------------------
# 飞书集成 / Feishu (Lark) Integration
# ----------------------------------------------------------------------------

# 飞书应用 ID / Feishu app ID
POCKET_FEISHU_APP_ID=

# 飞书应用密钥 / Feishu app secret
POCKET_FEISHU_APP_SECRET=

# 飞书验证 Token（url_verification 事件）/ Feishu verify token
POCKET_FEISHU_VERIFY_TOKEN=

# 飞书签名验证密钥（X-Lark-Signature，留空 = dev 模式跳过）
# Feishu signature secret (leave empty for dev mode skip)
POCKET_FEISHU_VERIFY_SECRET=

# 飞书加密密钥（V1 事件解密，V2 不需要）/ Feishu encrypt key (V1 only)
POCKET_FEISHU_ENCRYPT_KEY=

# ----------------------------------------------------------------------------
# 认证 / Authentication (Phase 0)
# ----------------------------------------------------------------------------

# JWT 签名密钥（生产环境必须修改！）/ JWT signing secret (MUST change in production!)
POCKET_JWT_SECRET=pocket-dev-insecure-secret

# 开发模式认证（允许 admin/admin 登录，生产必须不设或 false）
# Dev mode auth (allow admin/admin login, MUST be false in production)
POCKET_DEV_AUTH=

# 首用户 bootstrap 用户名（缺省 admin，仅 DEV_AUTH=true 时生效）
# First user bootstrap username (default admin, only when DEV_AUTH=true)
POCKET_AUTH_USER=

# 首用户 bootstrap 密码（缺省 admin，仅 DEV_AUTH=true 时生效）
# First user bootstrap password (default admin, only when DEV_AUTH=true)
POCKET_AUTH_PASS=

# ----------------------------------------------------------------------------
# AI/STT 后端 / AI/STT Backend (Phase 0)
# ----------------------------------------------------------------------------

# Groq API 密钥（云端 Whisper Large v3 Turbo 兜底）
# Groq API key (cloud Whisper Large v3 Turbo fallback)
POCKET_GROQ_API_KEY=

# kxmemory FastAPI 基础 URL（笔记/分类/SSOT/总结）
# kxmemory FastAPI base URL (notes/categorization/SSOT/summary)
POCKET_KXMEMORY_BASE_URL=

# ----------------------------------------------------------------------------
# 邮箱模块 / Email Module (Phase 0)
# ----------------------------------------------------------------------------

# 邮箱主密钥（AES-GCM 加密 IMAP 凭证，32字节 base64 编码）
# Email master key (AES-GCM encrypt IMAP credentials, 32 bytes base64)
POCKET_EMAIL_MASTER_KEY=

# Google OAuth 客户端 ID / Google OAuth client ID
POCKET_EMAIL_GOOGLE_CLIENT_ID=

# Google OAuth 客户端密钥 / Google OAuth client secret
POCKET_EMAIL_GOOGLE_CLIENT_SECRET=

# Microsoft OAuth 客户端 ID / Microsoft OAuth client ID
POCKET_EMAIL_MICROSOFT_CLIENT_ID=

# Microsoft OAuth 客户端密钥 / Microsoft OAuth client secret
POCKET_EMAIL_MICROSOFT_CLIENT_SECRET=

# OAuth 回调 URL（默认 http://localhost:8088/callback/email/oauth）
# OAuth callback URL (default http://localhost:8088/callback/email/oauth)
POCKET_EMAIL_OAUTH_REDIRECT_URL=

# 是否启用邮件抓取（默认 true；CI/dev 可关闭）
# Enable email fetching (default true; can disable in CI/dev)
POCKET_EMAIL_FETCH_ENABLED=

# ----------------------------------------------------------------------------
# 任务系统整合 / Task System Integration (Phase 5)
# ----------------------------------------------------------------------------

# ACC 系统 MCP 端点 / ACC system MCP endpoint
# 示例：https://mcp.kxpms.cn/acc/mcp
POCKET_MCP_BASE_URL=

# ACC MCP API 密钥（Bearer token）/ ACC MCP API key
POCKET_MCP_API_KEY=

# 跳过 TLS 验证（仅开发/自签证书，生产必须 false）
# Skip TLS verification (dev/self-signed only, MUST be false in production)
POCKET_MCP_INSECURE_TLS=

# ----------------------------------------------------------------------------
# 龙虾无状态 AI 网关 / Lobster Stateless AI Gateway (Phase C)
# ----------------------------------------------------------------------------

# 嵌入 API 基础 URL（默认 OpenAI）/ Embedding API base URL (default OpenAI)
POCKET_EMBED_BASE_URL=

# 嵌入 API 密钥 / Embedding API key
POCKET_EMBED_API_KEY=
# 或使用 OpenAI API 密钥 / Or use OpenAI API key
POCKET_OPENAI_API_KEY=

# 嵌入模型（默认 text-embedding-3-small）/ Embedding model
POCKET_EMBED_MODEL=text-embedding-3-small

# LLM API 基础 URL（默认 Groq）/ LLM API base URL (default Groq)
POCKET_LLM_BASE_URL=

# LLM API 密钥 / LLM API key
POCKET_LLM_API_KEY=
# 如果未设置，回退到 POCKET_GROQ_API_KEY / Falls back to POCKET_GROQ_API_KEY

# 默认 LLM 模型 / Default LLM model
POCKET_LLM_MODEL=

# ----------------------------------------------------------------------------
# 企业网关集成（可选）/ Enterprise Gateway Integration (Optional)
# ----------------------------------------------------------------------------

# llm-gateway-go 企业网关地址 / llm-gateway-go enterprise gateway URL
POCKET_LLM_GATEWAY_URL=

# llm-gateway 租户 API 密钥 / llm-gateway tenant API key
POCKET_LLM_GATEWAY_API_KEY=
